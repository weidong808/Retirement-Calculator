# Copy to .env.local and adjust for your machine.
# Do NOT commit .env.local — it is gitignored.

# Backend API base URL (no secrets required for local dev)
NEXT_PUBLIC_API_URL=http://localhost:5051

# Optional — override built-in developer intro (shown on About page & footer)
# NEXT_PUBLIC_DEVELOPER_NAME=Your Name
# NEXT_PUBLIC_DEVELOPER_TITLE=Your title or role
# NEXT_PUBLIC_DEVELOPER_BIO=Short intro about why you built RetireCheck.
# NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
# NEXT_PUBLIC_DEVELOPER_LINKEDIN=https://www.linkedin.com/in/yourprofile
# NEXT_PUBLIC_DEVELOPER_GITHUB=https://github.com/weidong808/Retirement-Calculator
# NEXT_PUBLIC_DEVELOPER_GITHUB_PROFILE=https://github.com/weidong808
