# Copy to .env.local and adjust for your machine.
# Do NOT commit .env.local — it is gitignored.

# Server-only — Next.js API routes proxy to the .NET backend (not exposed to the browser).
CALCULATOR_API_URL=http://127.0.0.1:5051

# Vercel production — set in Project Settings → Environment Variables:
# CALCULATOR_API_URL=https://your-api-host.example.com

# Optional — override built-in developer intro (shown on About page & footer)
# NEXT_PUBLIC_DEVELOPER_NAME=Your Name
# NEXT_PUBLIC_DEVELOPER_TITLE=Your title or role
# NEXT_PUBLIC_DEVELOPER_BIO=Short intro about why you built RetireCheck.
# NEXT_PUBLIC_CONTACT_EMAIL=contact@weidong-shi.com
# NEXT_PUBLIC_DEVELOPER_LINKEDIN=https://www.linkedin.com/in/yourprofile
# NEXT_PUBLIC_DEVELOPER_GITHUB_PROFILE=https://github.com/weidong808

# Optional — AI plan explainer. When unset, the feature is hidden and the
# calculator works exactly as before (deterministic results only).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# EXPLAINER_AI_DISABLED=1   # force-disable even if a key is set
